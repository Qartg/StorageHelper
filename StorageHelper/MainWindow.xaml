<Window x:Class="StorageHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StorageHelper"
        xmlns:Behaviors="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:vm="clr-namespace:StorageHelper.ViewModels"
        xmlns:view="clr-namespace:StorageHelper.Views"
        mc:Ignorable="d"
        Title="StorageHelper"
        Height="660" Width="1037" MinWidth="760"
        Background="{StaticResource WindowBackgroundBrush}">

    <Behaviors:Interaction.Triggers>
        <Behaviors:EventTrigger EventName="Loaded">
            <Behaviors:InvokeCommandAction Command="{Binding LoadedCommand}"/>
        </Behaviors:EventTrigger>
    </Behaviors:Interaction.Triggers>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ItemCardViewModel}">
            <view:ItemCard/>
        </DataTemplate>

        <Style x:Key="ManagerOnly" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsManagerMode}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ManagerHidden" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsManagerMode}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBackgroundBrush}"
                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1"
                Padding="16,10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="Инвентаризация"
                           Style="{StaticResource HeaderTitleText}" FontSize="17"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource ManagerOnly}" Margin="0,0,12,0" VerticalAlignment="Center">
                        <CheckBox Content="Неактивные" IsChecked="{Binding ShowInactive}"
                                  Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </Border>
                    <Border Style="{StaticResource ManagerOnly}" Background="{StaticResource AccentBrush}"
                            CornerRadius="6" Padding="10,4" Margin="0,0,8,0" VerticalAlignment="Center">
                        <TextBlock Text="Менеджер" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                    <Border Style="{StaticResource ManagerHidden}">
                        <Button Content="Войти как менеджер" Command="{Binding LoginCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </Border>
                    <Border Style="{StaticResource ManagerOnly}">
                        <Button Content="Выйти" Command="{Binding LogoutCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </Border>
                    <Border Style="{StaticResource ManagerOnly}" Margin="8,0,0,0">
                        <Button Content="Сводка заказа" Command="{Binding ReviewCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </Border>
                    <Border Style="{StaticResource ManagerOnly}" Margin="8,0,0,0">
                        <Button Content="+ Добавить" Command="{Binding AddCardCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </Border>
                </StackPanel>

                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FormTextBoxStyle}"
                         Tag="Поиск по названию или SKU…" 
                         MaxWidth="360" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding StorageItems}"
                 Background="Transparent" BorderThickness="0"
                 Padding="12"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ItemContainerStyle="{StaticResource CardListBoxItemStyle}">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
    </Grid>
</Window>
