<UserControl x:Class="StorageHelper.Views.AutomationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:StorageHelper.Views"
             mc:Ignorable="d"
             d:DesignWidth="580">

    <Border Background="{StaticResource CardBackgroundBrush}" Width="580" Padding="24,20">
        <DockPanel>

            <TextBlock DockPanel.Dock="Top" Text="Сборка корзины"
                       Style="{StaticResource HeaderTitleText}" Margin="0,0,0,14"/>

            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                <Grid>
                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold">
                        <Run Text="Обработано "/><Run Text="{Binding Processed, Mode=OneWay}"/><Run Text=" из "/><Run Text="{Binding Total, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock HorizontalAlignment="Right" Style="{StaticResource FieldLabelText}">
                        <Run Text="успешно "/><Run Text="{Binding SucceededCount, Mode=OneWay}"/><Run Text="  ·  ошибок "/><Run Text="{Binding FailedCount, Mode=OneWay}"/>
                    </TextBlock>
                </Grid>
                <ProgressBar Minimum="0" Maximum="{Binding Total}" Value="{Binding Processed, Mode=OneWay}"
                             Height="6" Margin="0,6,0,0"
                             Background="{StaticResource NeutralButtonBrush}"
                             Foreground="{StaticResource AccentBrush}" BorderThickness="0"/>
            </StackPanel>

            <Border DockPanel.Dock="Top" Background="{StaticResource InfoBannerBg}" BorderBrush="{StaticResource InfoBannerBorder}"
                    BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAwaitingLogin}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource InfoBannerText}" FontSize="12"
                           Text="🔑 Требуется вход в Ozon. Войдите в открывшемся окне браузера — сборка продолжится автоматически."/>
            </Border>

            <StackPanel DockPanel.Dock="Bottom">
                <Border CornerRadius="6" Padding="10,8" Margin="0,12,0,0" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Setter Property="Background" Value="{StaticResource WarnBannerBg}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource WarnBannerBorder}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ResultBanner}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ResultBanner}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ResultIsError}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource DangerBannerBg}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource DangerBannerBorder}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock TextWrapping="Wrap" FontSize="12" Text="{Binding ResultBanner}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource WarnBannerText}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ResultIsError}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource DangerBannerText}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="Закрыть" Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0"/>
                    <Button Content="СТОП" Command="{Binding StopCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0"/>
                    <Button Content="Запустить" Command="{Binding RunCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </StackPanel>

            <Border BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="6">
                <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Log}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1"
                                        Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                                   Margin="0,0,10,0" FontSize="15" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="•"/>
                                                    <Setter Property="Foreground" Value="{StaticResource PlaceholderTextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Running">
                                                            <Setter Property="Text" Value="⟳"/>
                                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Success">
                                                            <Setter Property="Text" Value="✓"/>
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Text" Value="✗"/>
                                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource CardTitleText}" FontSize="13"
                                                       Text="{Binding Title, TargetNullValue='—'}"/>
                                            <TextBlock Style="{StaticResource FieldLabelText}" TextTrimming="CharacterEllipsis">
                                                <Run Text="SKU "/><Run Text="{Binding Sku, Mode=OneWay}"/><Run Text="  ·  "/><Run Text="{Binding Message, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0"
                                                   Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"
                                                   Text="{Binding CapturedPrice, StringFormat='{}{0:0.##} ₽', TargetNullValue='—'}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

        </DockPanel>
    </Border>
</UserControl>
