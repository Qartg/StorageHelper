<UserControl x:Class="StorageHelper.Views.ItemCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:StorageHelper.Views"
             xmlns:myBehaivors="clr-namespace:StorageHelper.Behaviors"
             xmlns:Behaviors="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d"
             d:DesignWidth="230" d:DesignHeight="320">

    <Border Style="{StaticResource CardBorderStyle}" Width="230">
        <StackPanel>

            <!-- Картинка с заглушкой "нет фото" -->
            <Border Height="120" CornerRadius="8"
                    Background="{StaticResource PlaceholderBackgroundBrush}"
                    ClipToBounds="True">
                <Grid>
                    <TextBlock Text="нет фото"
                               Foreground="{StaticResource PlaceholderTextBrush}"
                               FontSize="12"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Image Source="{Binding ImageURL}" Stretch="UniformToFill"/>

                    <!-- Бейдж "нет в магазине" (когда IsOrderable = false) -->
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6"
                            Background="{StaticResource DangerBrush}" CornerRadius="4" Padding="6,2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOrderable}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="Нет в магазине" Foreground="White"
                                   FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Название и описание -->
            <TextBlock Text="{Binding Name}" Style="{StaticResource CardTitleText}" Margin="0,10,0,0"/>
            <TextBlock Text="{Binding Description}" Style="{StaticResource CardSubtleText}" Margin="0,2,0,0"/>

            <!-- SKU и поставщик -->
            <TextBlock Style="{StaticResource FieldLabelText}" Margin="0,6,0,0"
                       TextTrimming="CharacterEllipsis"
                       Text="{Binding Sku, StringFormat='SKU: {0}'}"/>
            <TextBlock Style="{StaticResource FieldLabelText}" Margin="0,1,0,0"
                       TextTrimming="CharacterEllipsis"
                       Text="{Binding Vendor, StringFormat='Поставщик: {0}'}"/>

            <!-- Целевой остаток (только для чтения; правка — в форме редактирования) -->
            <TextBlock Text="{Binding ParLevel, StringFormat='Цель: {0}'}"
                       Style="{StaticResource FieldLabelText}" Margin="0,1,0,0"/>

            <!-- Цена + индикатор роста vs прошлой -->
            <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                <TextBlock Style="{StaticResource FieldLabelText}" VerticalAlignment="Center"
                           Text="{Binding CurrentPrice, StringFormat='Цена: {0:0.##} ₽', TargetNullValue='Цена: —'}"/>
                <!-- бейдж роста (красный, когда цена выросла) -->
                <Border Margin="6,0,0,0" Padding="4,0" CornerRadius="3" VerticalAlignment="Center"
                        Background="{StaticResource DangerBrush}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPriceUp}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Foreground="White" FontSize="10" FontWeight="SemiBold"
                               Text="{Binding PriceChangePercent, StringFormat='▲ {0:P0}'}"/>
                </Border>
                <!-- бейдж снижения (зелёный, когда цена упала) -->
                <Border Margin="6,0,0,0" Padding="4,0" CornerRadius="3" VerticalAlignment="Center"
                        Background="{StaticResource SuccessBrush}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPriceDown}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Foreground="White" FontSize="10" FontWeight="SemiBold"
                               Text="{Binding PriceChangePercent, StringFormat='▼ {0:P0}'}"/>
                </Border>
            </StackPanel>

            <!-- Счётчик остатка на складе -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="–"
                        Command="{Binding MinusItemCountCommand}"
                        Style="{StaticResource CounterButtonStyle}"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                    <TextBlock Text="на складе" Style="{StaticResource FieldLabelText}"
                               HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding CurrentOnStorage, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CountInputStyle}" HorizontalAlignment="Center">
                        <Behaviors:Interaction.Behaviors>
                            <myBehaivors:NumericBoxBehavior/>
                        </Behaviors:Interaction.Behaviors>
                    </TextBox>
                </StackPanel>

                <Button Grid.Column="2" Content="+"
                        Command="{Binding PlusItemCountCommand}"
                        Style="{StaticResource PlusButtonStyle}"/>
            </Grid>

            <!-- Нужно дозаказать (когда остаток ниже цели) -->
            <Border Margin="0,10,0,0" Padding="8,4" CornerRadius="6"
                    Background="{StaticResource AccentBrush}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"
                           Text="{Binding ReOrderQuantity, StringFormat='Дозаказать: {0:0}'}"/>
            </Border>

            <!-- Редактирование — только в режиме менеджера (IsManagerMode у StorageViewModel) -->
            <Border Margin="0,10,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Value="True"
                                Binding="{Binding DataContext.IsManagerMode,
                                          RelativeSource={RelativeSource AncestorType=ListBox}}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Button Content="Изменить"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding DataContext.EditCardCommand,
                                          RelativeSource={RelativeSource AncestorType=ListBox}}"
                        CommandParameter="{Binding}"/>
            </Border>

        </StackPanel>
    </Border>
</UserControl>
