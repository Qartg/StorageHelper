<UserControl x:Class="StorageHelper.Views.ItemCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:StorageHelper.Views"
             xmlns:myBehaivors="clr-namespace:StorageHelper.Behaviors"
             xmlns:Behaviors="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d"
             d:DesignWidth="470" d:DesignHeight="260">

    <Border Style="{StaticResource CardBorderStyle}" Width="470" Height="260" Padding="0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="170" CornerRadius="10,0,0,10"
                    Background="{StaticResource PlaceholderBackgroundBrush}" ClipToBounds="True">
                <Grid>
                    <TextBlock Text="нет фото" Foreground="{StaticResource PlaceholderTextBrush}"
                               FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <Border CornerRadius="10,0,0,10">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding ImageURL}" Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>

                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6"
                            Background="{StaticResource DangerBrush}" CornerRadius="4" Padding="7,3">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOrderable}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="Нет в магазине" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Top">
                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="16" FontWeight="SemiBold"
                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="44"/>
                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                    <TextBlock Margin="0,6,0,0" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" Text="{Binding Sku, StringFormat='SKU: {0}'}"/>
                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" Text="{Binding Vendor, StringFormat='Поставщик: {0}'}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="19" FontWeight="SemiBold"
                                   Text="{Binding CurrentPrice, StringFormat='{}{0:N0} ₽', ConverterCulture=ru-RU, TargetNullValue='—'}"/>
                        <Border Margin="8,0,0,0" Padding="6,1" CornerRadius="4" VerticalAlignment="Center"
                                Background="{StaticResource DangerBrush}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPriceUp}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Foreground="White" FontSize="12" FontWeight="SemiBold"
                                       Text="{Binding PriceChangePercent, StringFormat='▲ {0:P0}'}"/>
                        </Border>
                        <Border Margin="8,0,0,0" Padding="6,1" CornerRadius="4" VerticalAlignment="Center"
                                Background="{StaticResource SuccessBrush}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPriceDown}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Foreground="White" FontSize="12" FontWeight="SemiBold"
                                       Text="{Binding PriceChangePercent, StringFormat='▼ {0:P0}'}"/>
                        </Border>
                        <TextBlock VerticalAlignment="Center" Margin="14,0,0,0" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="{Binding ParLevel, StringFormat='Цель: {0}'}"/>
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="на складе" Style="{StaticResource FieldLabelText}" Margin="2,0,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="–" Command="{Binding MinusItemCountCommand}"
                                    Style="{StaticResource CounterButtonStyle}" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding CurrentOnStorage, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource CountInputStyle}" Margin="8,0" VerticalAlignment="Center">
                                <Behaviors:Interaction.Behaviors>
                                    <myBehaivors:NumericBoxBehavior/>
                                </Behaviors:Interaction.Behaviors>
                            </TextBox>
                            <Button Content="+" Command="{Binding PlusItemCountCommand}"
                                    Style="{StaticResource PlusButtonStyle}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                        <Border Padding="8,4" CornerRadius="6" HorizontalAlignment="Right" Margin="0,0,0,6"
                                Background="{StaticResource AccentBrush}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Foreground="White" FontWeight="SemiBold" FontSize="12"
                                       Text="{Binding ReOrderQuantity, StringFormat='Дозаказать: {0:0}'}"/>
                        </Border>

                        <Border HorizontalAlignment="Right">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Value="True"
                                            Binding="{Binding DataContext.IsManagerMode,
                                                      RelativeSource={RelativeSource AncestorType=ListBox}}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Button Content="Изменить" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding DataContext.EditCardCommand,
                                                      RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>