<UserControl x:Class="StorageHelper.Views.ItemEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:StorageHelper.Views"
             xmlns:myBehaviors="clr-namespace:StorageHelper.Behaviors"
             xmlns:Behaviors="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d"
             d:DesignWidth="600">

    <Border Background="{StaticResource HeaderBackgroundBrush}" Width="600" Padding="24,20">
        <StackPanel>

            <TextBlock Text="{Binding Title}" Style="{StaticResource HeaderTitleText}" Margin="0,0,0,16"/>

            <Border Background="{StaticResource InfoBannerBg}" BorderBrush="{StaticResource InfoBannerBorder}"
                    BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAwaitingLogin}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource InfoBannerText}" FontSize="12"
                           Text="🔑 Требуется вход в аккаунт. Войдите в открывшемся окне браузера — сбор данных продолжится автоматически."/>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <TextBlock Text="Название" Style="{StaticResource FieldLabelText}" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}"/>

                    <TextBlock Text="SKU" Style="{StaticResource FieldLabelText}" Margin="0,12,0,3"/>
                    <TextBox Text="{Binding Sku, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}"/>
                    <Button Content="Подтянуть данные с магазина"
                            Command="{Binding FetchFromOzonCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            HorizontalAlignment="Left" Margin="0,8,0,0"/>

                    <TextBlock Text="Поставщик" Style="{StaticResource FieldLabelText}" Margin="0,12,0,3"/>
                    <TextBox Text="{Binding Vendor, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}"/>

                    <TextBlock Text="Цена, ₽" Style="{StaticResource FieldLabelText}" Margin="0,12,0,3"/>
                    <TextBox Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}">
                        <Behaviors:Interaction.Behaviors>
                            <myBehaviors:NumericBoxBehavior/>
                        </Behaviors:Interaction.Behaviors>
                    </TextBox>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Целевой остаток" Style="{StaticResource FieldLabelText}" Margin="0,0,0,3"/>
                            <TextBox Text="{Binding ParLevel, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBoxStyle}">
                                <Behaviors:Interaction.Behaviors>
                                    <myBehaviors:NumericBoxBehavior/>
                                </Behaviors:Interaction.Behaviors>
                            </TextBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="На складе" Style="{StaticResource FieldLabelText}" Margin="0,0,0,3"/>
                            <TextBox Text="{Binding CurrentOnStorage, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBoxStyle}">
                                <Behaviors:Interaction.Behaviors>
                                    <myBehaviors:NumericBoxBehavior/>
                                </Behaviors:Interaction.Behaviors>
                            </TextBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <CheckBox Content="Активен" IsChecked="{Binding IsActive}"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                        <CheckBox Content="В наличии" IsChecked="{Binding IsOrderable}"
                                  Foreground="{StaticResource TextPrimaryBrush}" Margin="20,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Картинка (URL)" Style="{StaticResource FieldLabelText}" Margin="0,0,0,3"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding ImageUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}"/>
                        <Border Grid.Column="2" Width="38" Height="38" CornerRadius="6"
                                Background="{StaticResource NeutralButtonBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                                ClipToBounds="True">
                            <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                        </Border>
                    </Grid>

                    <TextBlock Text="Описание" Style="{StaticResource FieldLabelText}" Margin="0,12,0,3"/>
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="92" MaxHeight="150" VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top"/>

                    <TextBlock Text="Заметки" Style="{StaticResource FieldLabelText}" Margin="0,12,0,3"/>
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="56" MaxHeight="100" VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top"/>
                </StackPanel>
            </Grid>

            <Border Background="{StaticResource DangerBannerBg}" BorderBrush="{StaticResource DangerBannerBorder}"
                    BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,12,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorText}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ErrorText}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorText}" Foreground="{StaticResource DangerBannerText}"
                           FontSize="12" TextWrapping="Wrap"/>
            </Border>

            <Grid Margin="0,20,0,0">
                <Button Content="Удалить" Command="{Binding DeleteCommand}"
                        HorizontalAlignment="Left"
                        Foreground="{StaticResource DangerBrush}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Editing}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Отмена" Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0"/>
                    <Button Content="Сохранить" Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </Grid>

        </StackPanel>
    </Border>
</UserControl>
