<UserControl x:Class="StorageHelper.Views.ItemEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:StorageHelper.Views"
             xmlns:myBehaviors="clr-namespace:StorageHelper.Behaviors"
             xmlns:Behaviors="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d"
             d:DesignWidth="380">

    <Border Background="{StaticResource CardBackgroundBrush}" Width="380" Padding="24,20">
        <StackPanel>

            <!-- Заголовок -->
            <TextBlock Text="{Binding Title}" Style="{StaticResource HeaderTitleText}" Margin="0,0,0,16"/>

            <!-- Название -->
            <TextBlock Text="Название" Style="{StaticResource FieldLabelText}" Margin="0,0,0,3"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FormTextBoxStyle}"/>

            <!-- SKU -->
            <TextBlock Text="SKU" Style="{StaticResource FieldLabelText}" Margin="0,12,0,3"/>
            <TextBox Text="{Binding Sku, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FormTextBoxStyle}"/>

            <!-- Поставщик -->
            <TextBlock Text="Поставщик" Style="{StaticResource FieldLabelText}" Margin="0,12,0,3"/>
            <TextBox Text="{Binding Vendor, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FormTextBoxStyle}"/>

            <!-- Заметки -->
            <TextBlock Text="Заметки" Style="{StaticResource FieldLabelText}" Margin="0,12,0,3"/>
            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FormTextBoxStyle}"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     MinHeight="56" VerticalScrollBarVisibility="Auto"
                     VerticalContentAlignment="Top"/>

            <!-- Цель / На складе -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Целевой остаток" Style="{StaticResource FieldLabelText}" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding ParLevel, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}">
                        <Behaviors:Interaction.Behaviors>
                            <myBehaviors:NumericBoxBehavior/>
                        </Behaviors:Interaction.Behaviors>
                    </TextBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="На складе" Style="{StaticResource FieldLabelText}" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding CurrentOnStorage, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}">
                        <Behaviors:Interaction.Behaviors>
                            <myBehaviors:NumericBoxBehavior/>
                        </Behaviors:Interaction.Behaviors>
                    </TextBox>
                </StackPanel>
            </Grid>

            <!-- Активность -->
            <CheckBox Content="Активен" IsChecked="{Binding IsActive}"
                      Foreground="{StaticResource TextPrimaryBrush}" Margin="0,16,0,0"/>

            <!-- Ошибка -->
            <TextBlock Text="{Binding ErrorText}" Foreground="{StaticResource DangerBrush}"
                       FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorText}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ErrorText}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Отмена" Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0"/>
                <Button Content="Сохранить" Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>

        </StackPanel>
    </Border>
</UserControl>
